{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "on-my-way-staging",
  "main": "./worker.mjs",
  "compatibility_date": "2026-07-11",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.4-mini",
    "APP_ENV": "staging",
    "APPLE_LOGIN_VISIBLE": "false",
    "ALLOW_DEV_LOGIN": "false",
    "ALLOW_DEMO_BILLING": "false",
    "PAYMENTS_ENABLED": "false"
  },
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "0",
      "simple": {
        "limit": 5,
        "period": 60
      }
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "GUEST_PLAN_DRAFTS",
        "class_name": "GuestPlanDraftObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "guest-plan-drafts-v1",
      "new_sqlite_classes": ["GuestPlanDraftObject"]
    }
  ]
}
