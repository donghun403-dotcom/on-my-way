{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "on-my-way",
  "main": "./worker.mjs",
  "compatibility_date": "2026-07-11",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.4-mini"
  },
  "kv_namespaces": [
    {
      "binding": "USERS_KV",
      "id": "04d136e6bcef4de7bb8a515856dd48f6"
    }
  ],
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "48117",
      "simple": {
        "limit": 5,
        "period": 60
      }
    }
  ],
  "triggers": {
    "crons": ["15 0 * * *"]
  }
}
