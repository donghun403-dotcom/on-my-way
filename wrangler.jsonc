{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "on-my-way-nonproduction",
  "main": "./worker.mjs",
  "compatibility_date": "2026-07-11",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.4-mini",
    "APP_ENV": "preview",
    "ALLOW_DEV_LOGIN": "false",
    "ALLOW_DEMO_BILLING": "false",
    "PAYMENTS_ENABLED": "false"
  },
  "kv_namespaces": [
    {
      "binding": "USERS_KV",
      "id": "dcc40a9a86414ac8814ef59a7e78ab80"
    }
  ],
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "48118",
      "simple": {
        "limit": 5,
        "period": 60
      }
    }
  ]
}
